JWT_SECRET=replace_with_a_long_random_secret_string_here
PORT=3000
NODE_ENV=development
DB_PATH=./data/msn.db

# object storage
OBJECT_STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./data/uploads
